---
import NavbarPorfolio from "../components/NavbarPorfolio.astro";
const { title, lang, description } = Astro.props;
import { Font } from "astro:assets";

const t = Astro.locals.t.seo;
const canonicalUrl = new URL(Astro.url.pathname, "https://aperezg.dev").href;
const ogLocale = (lang ?? Astro.locals.lang) === "en" ? "en_US" : "es_ES";
const pageTitle = title ?? "aperezg.dev";
const metaDescription = description ?? t.description;

const pathname = Astro.url.pathname;
const esUrl = new URL(pathname.replace(/^\/(en|es)\//, "/es/"), "https://aperezg.dev").href;
const enUrl = new URL(pathname.replace(/^\/(en|es)\//, "/en/"), "https://aperezg.dev").href;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-roboto" preload />
    <style>
      body {
        margin: 0;
        font-family: var(--font-roboto), sans-serif;
        background: #f5f5f5;
        color: #333;
        width: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      main {
        max-width: 900px;
      }
    </style>
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Alex Perez Garcia" />
    <meta name="description" content={metaDescription} />
    <meta
      name="keywords"
      content="Alex Perez Garcia, aperezg.dev, portfolio, developer, software engineer, projects, blog, backend developer, fullstack developer"
    />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content="https://aperezg.dev/portfolio-capture.webp" />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content="https://aperezg.dev/portfolio-capture.webp" />
    <slot name="head" />
  </head>
  <body>
    <slot name="navbar">
      <NavbarPorfolio />
    </slot>
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  main {
    width: 100%;
    min-height: 80vh;
  }

  span {
    color: gray;
    animation: colorChange 3s infinite;
  }

  h1 {
    font-size: 2.5rem;
  }

  h3 {
    font-size: 1.5rem;
    margin-top: -0.5rem;
    color: #555;
  }

  @keyframes colorChange {
    0% {
      color: gray;
    }
    50% {
      color: black;
    }
    100% {
      color: gray;
    }
  }
</style>
